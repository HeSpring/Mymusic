{
  "name": "mymusic",
  "version": "1.0.0",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "dist:win": "npm run build && set \"ELECTRON_BUILDER_BINARIES_MIRROR=https://registry.npmmirror.com/-/binary/electron-builder-binaries/\" && electron-builder --win nsis --publish never"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "framer-motion": "^12.38.0",
    "howler": "^2.2.4",
    "lodash": "^4.18.1",
    "lucide-react": "^1.7.0",
    "music-metadata": "^11.12.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^34.0.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.mymusic.player",
    "productName": "MyMusic",
    "compression": "maximum",
    "directories": {
      "output": "release6"
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "files": [
      "out/**",
      "resources/**",
      "package.json",
      "!resources/icon.png",
      "!**/*.map",
      "!**/*.md",
      "!**/*.txt",
      "!**/test{,s}/**",
      "!**/__tests__/**",
      "!**/*.spec.*",
      "!**/*.test.*",
      "!**/node_modules/**/@types/**",
      "!**/node_modules/**/typescript/**"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
